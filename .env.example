# Local SQLite database for Prisma (dev). Copy to .env before running db:push.
DATABASE_URL="file:./dev.db"

# Which ProductRepository the Next app reads from:
#   unset (default) → the full ingested SQLite catalog
#       (first run: npm run db:push && npm run db:seed && npm run db:ingest)
#   mock → the 17-item in-memory mock; works with no database, for quick UI work
# GREENLENS_REPO=mock
