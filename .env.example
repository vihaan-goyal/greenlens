# PostgreSQL connection string (Railway in prod, local Postgres in dev).
# Railway provides this as DATABASE_URL in the service variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/greenlens"

# Which ProductRepository the Next app reads from:
#   unset (default) → the full ingested Postgres catalog
#   mock → the 17-item in-memory mock; works with no database, for quick UI work
# GREENLENS_REPO=mock

# Amazon PA-API credentials (optional — enriches Amazon product matching).
# Get these from Associates Central → Tools → Product Advertising API.
# AMAZON_PA_ACCESS_KEY=
# AMAZON_PA_SECRET_KEY=
# AMAZON_PA_PARTNER_TAG=greenlens-20
