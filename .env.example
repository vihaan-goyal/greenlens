# Local SQLite database for Prisma (dev). Copy to .env before running db:push.
DATABASE_URL="file:./dev.db"

# Which ProductRepository the Next app reads from:
#   prisma → the seeded SQLite catalog (run: npm run db:push && npm run db:seed)
#   unset / anything else → the in-memory mock repository (default)
# GREENLENS_REPO=prisma
